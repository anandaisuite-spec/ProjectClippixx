# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=clipixx
DB_POOL_MAX=20
DB_SSL=false

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Firebase Admin SDK — provide credentials ONE of two ways:
#
#   (A) PRODUCTION / Docker / CasaOS (recommended): paste the whole service-account
#       JSON as a single env var. Survives gitignore and is never baked into the
#       image. Raw JSON or base64 both work (base64 avoids newline mangling):
#         FIREBASE_SERVICE_ACCOUNT_JSON=<base64-or-raw-json>
#
#   (B) LOCAL DEV: point to the JSON file on disk (this file is gitignored, so it
#       only works when physically present):
#         FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
#
# If BOTH are set, FIREBASE_SERVICE_ACCOUNT_JSON wins.
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Production deployment values (CasaOS / local network) ──────────────────
# When deployed, set these for the real deployment. Because Express serves the
# SPA and /api from the SAME origin (port 5000), same-origin requests need no
# CORS entry — but list any extra origins (e.g. a domain) here, comma-separated.
#   NODE_ENV=production
#   CORS_ORIGIN=http://192.168.1.10:5000,https://your-domain.com
#   FRONTEND_URL=http://192.168.1.10:5000

# Cloudflare Turnstile — server-side secret (verify tokens). Site key is a
# frontend (VITE_) var. If unset in production, CAPTCHA verification is skipped.
# TURNSTILE_SECRET_KEY=your_turnstile_secret
